{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    ":dependencyDashboard",
    ":semanticCommits",
    ":automergeBranch",
  ],
  schedule: ["at any time"],
  "git-submodules": {
    enabled: true,
  },
}
